# Gemini (문서 분석 / 쉬운말 번역)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# RAG 임베딩 (로컬 한국어 모델 - sentence-transformers, HF 캐시 사용)
EMBEDDING_MODEL=jhgan/ko-sroberta-multitask

# Google Cloud Vision (OCR) - 서비스 계정 JSON 키 파일 경로
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\vision-service-account.json

# RAG 정책 코퍼스
CORPUS_PATH=data/corpus.json
RAG_TOP_K=3
# 코사인 유사도 임계값(미달은 신호/키워드 폴백으로만 포함). 0~1.
RAG_MIN_SCORE=0.35

# CORS - 프론트엔드 주소. 여러 개면 JSON 배열로. 기본은 전체 허용.
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
